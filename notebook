    "def normalize_json_column(df, column, movie_id_col='id'):\n",
    "    records = []\n",
    "\n",
    "    for _, row in df.iterrows():\n",
    "        try:\n",
    "            items = json.loads(row[column])\n",
    "            for item in items:\n",
    "                item['movie_id'] = row[movie_id_col]\n",
    "                records.append(item)\n",
    "        except:\n",
    "            continue\n",
    "\n",
    "    return pd.DataFrame(records)"
   ]
